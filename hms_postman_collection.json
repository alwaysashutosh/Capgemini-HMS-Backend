{
	"info": {
		"_postman_id": "89b32996-2ef0-4333-9c3d-cfaa209ff16c",
		"name": "HMS Production API (v1) - COMPLETE",
		"description": "Exhaustive collection for testing the modernized Hospital Management System (v1). Covers all modules with standardized RESTful v1 prefixes, pagination support, and soft-delete capabilities.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. User Authentication",
			"item": [
				{
					"name": "Sign-in (Login)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@hms.com\",\n  \"password\": \"admin123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/api/v1/auth/signin"
					}
				},
				{
					"name": "Sign-up (Register)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"physician_alice\",\n  \"email\": \"alice@hms.com\",\n  \"password\": \"password123\",\n  \"role\": [\"doctor\"]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/api/v1/auth/signup"
					}
				},
				{
					"name": "Token Refresh",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/api/v1/auth/refresh"
					}
				}
			]
		},
		{
			"name": "2. Patient Management",
			"item": [
				{
					"name": "List Patients (Paginated)",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/v1/patients?page=0&size=10&sort=name,asc"
					}
				},
				{
					"name": "Get Patient by SSN",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/v1/patients/1001"
					}
				},
				{
					"name": "Register New Patient",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"ssn\": 1003,\n  \"name\": \"Alice Brown\",\n  \"address\": \"789 Pine Rd\",\n  \"phone\": \"555-0303\",\n  \"insuranceId\": \"INS-003\",\n  \"pcpId\": 101\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/api/v1/patients"
					}
				},
				{
					"name": "Update Patient Details",
					"request": {
						"method": "PUT",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Alice B. Updated\",\n  \"address\": \"790 Pine Rd Updated\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/api/v1/patients/1003"
					}
				},
				{
					"name": "Delete Patient (Soft)",
					"request": {
						"method": "DELETE",
						"url": "{{baseUrl}}/api/v1/patients/1003"
					}
				},
				{
					"name": "Search Patients",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/v1/patients/search?query=Alice"
					}
				}
			]
		},
		{
			"name": "3. Staff: Physicians",
			"item": [
				{ "name": "List Physicians", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/physicians" } },
				{ "name": "Get Physician Details", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/physicians/101" } },
				{ "name": "Add Physician", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"employeeId\": 104, \"name\": \"Dr. David\", \"position\": \"Neurologist\", \"ssn\": 222333}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/physicians" } },
				{ "name": "Update Physician", "request": { "method": "PUT", "body": { "mode": "raw", "raw": "{\"name\": \"Dr. David Updated\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/physicians/104" } },
				{ "name": "Soft Delete Physician", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/physicians/104" } }
			]
		},
		{
			"name": "4. Staff: Nurses",
			"item": [
				{ "name": "List Nurses", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/nurses" } },
				{ "name": "Get Nurse Details", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/nurses/201" } },
				{ "name": "Add Nurse", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"employeeId\": 203, \"name\": \"Nurse Nina\", \"position\": \"ICU Specialist\", \"registered\": true, \"ssn\": 444555}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/nurses" } },
				{ "name": "Update Nurse", "request": { "method": "PUT", "body": { "mode": "raw", "raw": "{\"name\": \"Nurse Nina Updated\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/nurses/203" } },
				{ "name": "Soft Delete Nurse", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/nurses/203" } }
			]
		},
		{
			"name": "5. Infrastructure: Rooms",
			"item": [
				{ "name": "List All Rooms", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/rooms?page=0&size=20" } },
				{ "name": "Get Available Rooms", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/rooms/available" } },
				{ "name": "Add New Room", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"roomNumber\": 301, \"roomType\": \"Luxury\", \"blockFloor\": 2, \"blockCode\": 1, \"unavailable\": false}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/rooms" } },
				{ "name": "Soft Delete Room", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/rooms/301" } }
			]
		},
		{
			"name": "6. Infrastructure: Departments",
			"item": [
				{ "name": "List Departments", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/departments" } },
				{ "name": "Create Department", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"departmentId\": 3, \"name\": \"Oncology\", \"headId\": 102}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/departments" } },
				{ "name": "Set Department Head", "request": { "method": "PUT", "url": "{{baseUrl}}/api/v1/departments/3/head?physicianId=101" } },
				{ "name": "Affiliate Physician to Dept", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"physicianId\": 101, \"departmentId\": 3, \"primary\": true}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/departments/affiliate" } }
			]
		},
		{
			"name": "7. Clinical: Stays (Admissions)",
			"item": [
				{ "name": "Patient Check-in", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"patientSsn\": 1002, \"roomNumber\": 101, \"stayStart\": \"2026-04-10T10:00:00\", \"notes\": \"Observation required\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/stays" } },
				{ "name": "Patient Check-out (Discharge)", "request": { "method": "PUT", "url": "{{baseUrl}}/api/v1/stays/1?notes=Discharged after recovery." } },
				{ "name": "Get Active Stays", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/stays/active" } },
				{ "name": "List Stay History", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/stays" } }
			]
		},
		{
			"name": "8. Clinical: Appointments",
			"item": [
				{ "name": "List Appointments", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/appointments?page=0&size=10" } },
				{ "name": "Book Appointment", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"appointmentId\": 10, \"patientSsn\": 1001, \"physicianId\": 103, \"prepnurseId\": 201, \"start\": \"2026-04-12T09:00:00\", \"end\": \"2026-04-12T10:00:00\", \"examinationRoom\": \"Room C-1\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/appointments" } },
				{ "name": "Reschedule Appointment", "request": { "method": "PUT", "body": { "mode": "raw", "raw": "{\"start\": \"2026-04-13T09:00:00\", \"end\": \"2026-04-13T10:00:00\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/appointments/10" } },
				{ "name": "Cancel Appointment", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/appointments/10" } }
			]
		},
		{
			"name": "9. Pharmacy: Medications",
			"item": [
				{ "name": "List All Medications", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/medications" } },
				{ "name": "Add to Catalog", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"code\": 603, \"name\": \"Ibuprofen\", \"brand\": \"Advil\", \"description\": \"Pain reliever\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/medications" } },
				{ "name": "Search Medication", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/medications/search?query=Ibu" } }
			]
		},
		{
			"name": "10. Pharmacy: Prescriptions",
			"item": [
				{ "name": "Create Prescription", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"physicianId\": 101, \"patientSsn\": 1001, \"medicationCode\": 601, \"dose\": \"500mg x 2\", \"appointmentId\": 1}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/prescriptions" } },
				{ "name": "Get Patient Prescriptions", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/prescriptions/patient/1001" } }
			]
		},
		{
			"name": "11. Procedures: Catalog",
			"item": [
				{ "name": "List Procedures", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/procedures" } },
				{ "name": "Add Procedure", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"code\": 503, \"name\": \"MRI Scan\", \"cost\": 1200.00}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/procedures" } },
				{ "name": "Search Procedure", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/procedures/search?query=MRI" } }
			]
		},
		{
			"name": "12. Procedures: Records",
			"item": [
				{ "name": "Record Procedure Result", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"patientSsn\": 1001, \"procedureCode\": 501, \"stayId\": 1, \"physicianId\": 101, \"notes\": \"Successful\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/medical-records/procedure" } },
				{ "name": "Get Patient History", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/medical-records/patient/1001" } }
			]
		},
		{
			"name": "13. Procedures: Certifications",
			"item": [
				{ "name": "Certify Physician Skill", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"physicianId\": 101, \"procedureCode\": 503}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/certifications" } },
				{ "name": "Get Physician Certifications", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/certifications/physician/101" } }
			]
		},
		{
			"name": "14. Reporting & Analytics",
			"item": [
				{ "name": "Dashboard Summary", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/dashboard/summary" } },
				{ "name": "Department Stats", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/dashboard/departments" } }
			]
		},
		{
			"name": "15. Patient Portal (Self-Service)",
			"item": [
				{ "name": "Get My Profile", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/patients/me" } },
				{ "name": "Update My Profile", "request": { "method": "PUT", "body": { "mode": "raw", "raw": "{\"name\": \"Patient Name Updated\", \"address\": \"New Address\", \"phone\": \"555-1234\"}", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/api/v1/patients/me" } },
				{ "name": "Get My Appointments", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/appointments/my" } },
				{ "name": "Get My Prescriptions", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/prescriptions/my" } },
				{ "name": "Get My Stays", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/stays/my" } },
				{ "name": "Get My Medical Records", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/medical-records/my" } }
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8081" },
		{ "key": "token", "value": "" },
		{ "key": "refreshToken", "value": "" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
	}
}
